// Build settings for a project generated by tooling (Tuist / XcodeGen /
// Bazel's rules_apple) that does not check in a .xcodeproj / .xcworkspace.
// Lives in a directory that is a *sibling* of the app target, not an
// ancestor of its Info.plist / entitlements.
URL_SCHEME_DOMAIN_PREFIX = generatedapp
UNIVERSAL_LINKS_DOMAIN = generated.example.com
