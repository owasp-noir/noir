<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee" version="6.0">
  <servlet>
    <servlet-name>RestApplication</servlet-name>
    <servlet-class>com.example.RestApplication</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>RestApplication</servlet-name>
    <url-pattern>/services/*</url-pattern>
  </servlet-mapping>
  <servlet>
    <servlet-name>LegacyApplication</servlet-name>
    <servlet-class>com.legacy.LegacyApplication</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LegacyApplication</servlet-name>
    <url-pattern>/legacy/*</url-pattern>
  </servlet-mapping>
</web-app>
